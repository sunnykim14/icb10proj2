# Python 데이터 분석 프로젝트용 .gitignore
# ------------------------------------------
# Python 바이트코드 및 캐시 파일
__pycache__/
*.py[cod]
*$py.class

# 가상 환경 디렉터리 (uv 사용 시 .venv)
.venv/

# Jupyter Notebook 체크포인트
.ipynb_checkpoints/

# 데이터 파일 (대용량 또는 민감 데이터)
*.csv
*.tsv
*.xlsx
*.xls
*.json
*.parquet
*.pkl
*.h5
*.npy

# 환경 설정 파일 (비밀키, API 키 등)
.env
.env.*

# 로그 파일
*.log

# 메타데이터 및 임시 파일
.DS_Store
Thumbs.db

# VSCode 설정 파일 (필요 시 제외)
.vscode/

# 기타 IDE 설정 파일
.idea/

# 빌드/배포 디렉터리 (예: dist, build)
build/
Dist/

# 파이썬 실행 결과 파일 (예: .out, .exe 등)
*.out
*.exe

# 기타 무시하고 싶은 파일/디렉터리 추가
# (필요에 따라 아래 라인을 편집하세요)
.*
! **/
! **/.dockerignore
! **/.streamlit/**
